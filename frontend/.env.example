# DegreeTrackr Frontend Environment Variables
# Copy this file to .env.local and fill in real values.

# ── Clerk Auth ─────────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Convex ─────────────────────────────────────────────────────────────────────
# Dev deployment: https://hip-lynx-867.convex.cloud
# Production deployment: configure after running `npx convex deploy`
VITE_CONVEX_URL=https://hip-lynx-867.convex.cloud

# Set to '0' to disable Convex entirely and fall back to Flask for all calls.
# VITE_ENABLE_CONVEX=1

# ── Legacy /api bridge (required for remaining auth/evaluation/schedule seams) ─
# Set this when you need Clerk session exchange or any deferred /api-backed flow.
# VITE_API_BASE_URL=http://localhost:5000
