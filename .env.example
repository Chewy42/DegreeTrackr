# DegreeTrackr serverless environment example.
# Frontend runtime: Vite + React + Clerk + Convex.
# Supporting providers: Resend, Polar, Cloudflare Pages.
# This repo no longer ships a local Flask/Supabase backend.

CLIENT_PORT=3333

# Frontend auth/runtime
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CONVEX_URL=

# Optional legacy bridge for any not-yet-migrated API seam.
# Leave unset for the standard local workflow.
VITE_API_BASE_URL=

# Service providers
RESEND_API_KEY=
POLAR_ACCESS_TOKEN=
POLAR_ORGANIZATION_ID=

# Cloudflare Pages deployment
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_PROJECT=
