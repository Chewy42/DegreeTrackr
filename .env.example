# DegreeTrackr serverless environment example.
# Frontend runtime: Vite + React + Clerk + Convex.
# Supporting providers: Resend, Polar, Cloudflare Pages.
# This repo no longer ships a local Flask/Supabase backend.

CLIENT_PORT=3333

# Frontend auth/runtime (required)
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CONVEX_URL=

# Remaining bridge-backed flows still require this today for production and
# any local workflow that exercises Clerk session exchange or deferred /api seams.
VITE_API_BASE_URL=

# Service providers
RESEND_API_KEY=
POLAR_ACCESS_TOKEN=
POLAR_ORGANIZATION_ID=

# Cloudflare Pages deployment metadata / auth
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_PROJECT=
