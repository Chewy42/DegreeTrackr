modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "EduTrackr"
waitForPort = 80

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "EduTrackr"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 3333

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3333
externalPort = 80



[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd frontend && npm run preview"]
build = ["sh", "-c", "npm run build"]
