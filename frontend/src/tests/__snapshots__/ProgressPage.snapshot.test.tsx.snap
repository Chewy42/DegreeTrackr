exports[`ProgressPage snapshot regression > matches snapshot with 0 courses (empty state) 1`] = `"<div class="w-full max-w-7xl mx-auto p-4 md:p-6"><div class="flex flex-col items-center justify-center h-64 text-center" role="status" aria-live="polite"><span class="text-4xl text-slate-400 mb-3" aria-hidden="true" data-icon="alert"></span><h3 class="text-lg font-semibold text-slate-700 mb-1">No Progress Data Available</h3><p class="text-sm text-slate-500 max-w-md">Upload your program evaluation PDF first to see your academic progress visualized here.</p></div></div>"`;

exports[`ProgressPage snapshot regression > matches snapshot with fixed progress data (2 completed, 1 in-progress, GPA 3.5, 45/120) 1`] = `"<div class="w-full max-w-7xl mx-auto p-4 md:p-6 space-y-6"><div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4"><div><h1 class="text-2xl md:text-3xl font-bold text-slate-800">Alex Smith's Progress</h1><p class="text-sm text-slate-500 mt-1">B.S. Computer Science • Expected Graduation: Spring 2027</p></div><button type="button" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors"><span class="text-base" aria-hidden="true" data-icon="refresh"></span>Refresh Data</button></div><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4"><div data-testid="degree-progress-card">progress:38% earned:45/120 ip:3</div><div class="bg-white rounded-2xl border border-slate-200 p-5 shadow-sm hover:shadow-md transition-shadow"><div class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Overall GPA</div><div class="text-3xl font-bold text-slate-800">3.50</div><div class="text-xs text-slate-500 mt-1">🌟 Dean's List eligible</div></div><div class="bg-white rounded-2xl border border-slate-200 p-5 shadow-sm hover:shadow-md transition-shadow"><div class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Major GPA</div><div class="text-3xl font-bold text-slate-800">3.50</div><div class="text-xs text-slate-500 mt-1">👍 Solid performance</div></div><div class="bg-white rounded-2xl border border-slate-200 p-5 shadow-sm hover:shadow-md transition-shadow"><div class="text-xs font-medium text-slate-500 uppercase tracking-wide mb-1">Credits Remaining</div><div class="text-3xl font-bold text-slate-800">72</div><div class="text-xs text-slate-500 mt-1">📚 3 in progress</div></div></div><div class="grid grid-cols-1 lg:grid-cols-2 gap-6"><div data-testid="credit-chart">earned:45 ip:3 needed:72 reqs:2</div><div data-testid="gpa-chart">courses:2</div></div><div class="grid grid-cols-1 lg:grid-cols-2 gap-6"><div data-testid="requirements-checklist">reqs:2</div><div data-testid="course-timeline">courses:3</div></div><div data-testid="milestones">reqs:2</div></div>"`;
