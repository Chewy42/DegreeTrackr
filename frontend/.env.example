# DegreeTrackr Frontend Environment Variables
# Copy this file to .env.local for local dev, or configure the same values
# in Cloudflare Pages for hosted deploys.

# ── Clerk Auth (required everywhere) ───────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Convex (required everywhere) ───────────────────────────────────────────────
# Dev deployment example:
# VITE_CONVEX_URL=https://hip-lynx-867.convex.cloud
# Production deployment: replace this with your production Convex URL after
# running `npx convex deploy` against the production project.
VITE_CONVEX_URL=

# Optional toggle: set to '0' only when intentionally disabling Convex.
# VITE_ENABLE_CONVEX=1

# ── Legacy /api bridge (still required in production today) ────────────────────
# Remaining bridge-backed flows still include Clerk session exchange, backend
# health checks, some schedule endpoints, and PDF parsing/preview for program
# evaluations. Keep this configured until those seams are fully removed.
# Local example:
# VITE_API_BASE_URL=http://localhost:5000
VITE_API_BASE_URL=

# Optional routing override when Pages serves under a subpath.
# VITE_ROUTER_BASENAME=/
